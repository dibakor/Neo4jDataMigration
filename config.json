{
  "source": {
    "uri": "bolt://source-server:7687",
    "user": "neo4j",
    "password": "your-source-password",
    "database": "neo4j"
  },
  "target": {
    "uri": "bolt://target-server:7687",
    "user": "neo4j",
    "password": "your-target-password",
    "database": "neo4j"
  },
  "migration": {
    "batch_size": 500,
    "max_retries": 3,
