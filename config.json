    "dry_run": false,
    "verbose": true,
    "labels_to_migrate": [
      "Person",
      "Movie"
    ],
    "relationship_types_to_migrate": []
  },
  "logging": {
    "log_file": "migration.log",
    "log_level": "INFO"
  }
}